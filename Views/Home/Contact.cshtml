@model CoreWebSite.Models.ContactForm

@{
    ViewData["Title"] = "Contact Us";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="fw-bold text-center mb-4">Contact Us</h1>
            <p class="text-center text-muted mb-5">Have any questions? We'd love to hear from you.</p>

            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <form asp-action="Contact" method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter your full name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" placeholder="Enter your email address" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Message" class="form-label fw-bold"></label>
                            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your message here..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">Submit Message</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
